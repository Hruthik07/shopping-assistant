# =============================================================================
# E-Commerce Shopping Assistant — Environment Variables
# Copy this file to .env and fill in the values before starting the app.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic          # anthropic | openai
LLM_MODEL=claude-3-5-haiku-20241022
LLM_TEMPERATURE=0.3

# Anthropic (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# External Product / Search APIs
# -----------------------------------------------------------------------------
TAVILY_API_KEY=
SERPER_API_KEY=

# Amazon Product Advertising API
AMAZON_API_KEY=
AMAZON_SECRET_KEY=
AMAZON_ASSOCIATE_TAG=

# Retailer APIs (all optional — app degrades gracefully without them)
EBAY_API_KEY=
WALMART_API_KEY=
BESTBUY_API_KEY=
ETSY_API_KEY=
PRICEGRABBER_API_KEY=
SHOPZILLA_API_KEY=

# Coupon / Promo APIs
HONEY_API_KEY=
RETAILMENOT_API_KEY=
COUPONFOLLOW_API_KEY=

# Currency conversion
EXCHANGERATE_API_KEY=

# -----------------------------------------------------------------------------
# Database
# Use the PostgreSQL URL in production; SQLite is for local dev only.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://appuser:changeme@localhost:5432/shopping_assistant
# DATABASE_URL=sqlite:///./shopping_assistant.db   # local dev shortcut

# -----------------------------------------------------------------------------
# Redis Cache
# Use rediss:// (TLS) for production ElastiCache; redis:// for local dev.
# -----------------------------------------------------------------------------
REDIS_URL=redis://:changeme@localhost:6379/0
# REDIS_URL=rediss://:token@<elasticache-host>:6379/0   # production TLS
CACHE_ENABLED=true

# Cache TTLs (seconds)
CACHE_LLM_RESPONSE_TTL=3600
CACHE_PRODUCT_SEARCH_TTL=1800
CACHE_SESSION_TTL=3600
CACHE_EMBEDDING_TTL=86400

# -----------------------------------------------------------------------------
# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=
API_KEY=                          # X-API-Key header value; leave blank to disable auth in dev

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins. "*" is blocked in production.
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3565
# CORS_ORIGINS=https://your-domain.com   # production

# -----------------------------------------------------------------------------
# Environment / Runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=development           # development | staging | production
LOG_LEVEL=INFO
LOG_FORMAT=text                   # text | json  (json recommended for production / CloudWatch)
LOG_FILE=logs/app.log

API_HOST=0.0.0.0
API_PORT=3565
RATE_LIMIT_PER_MINUTE=60

# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
# Name of the Secrets Manager secret that holds production keys (see Step 2 of infra guide)
AWS_SECRETS_NAME=                 # e.g. prod/shopping-assistant/secrets

# AWS X-Ray distributed tracing
XRAY_ENABLED=false

# CloudWatch custom metrics
CLOUDWATCH_ENABLED=false
CLOUDWATCH_NAMESPACE=ShoppingAssistant/Application

# AWS Bedrock (optional alternative LLM backend)
BEDROCK_ENABLED=false

# -----------------------------------------------------------------------------
# Observability — Langfuse
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PROJECT_NAME=shopping-assistant
LANGFUSE_ENABLED=true

# -----------------------------------------------------------------------------
# Observability — DeepEval
# -----------------------------------------------------------------------------
DEEPEVAL_API_KEY=
DEEPEVAL_ENABLED=true

# -----------------------------------------------------------------------------
# Debug (never enable in production)
# -----------------------------------------------------------------------------
DEBUG_PROMPTS=false
